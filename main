function buyAndEquipMask()
    local player = game.Players.LocalPlayer
    local char = player.Character or player.CharacterAdded:Wait()
    local root_ = char:FindFirstChild("HumanoidRootPart")
    if not root_ then return end

    -- solta tudo da mão antes de comprar
    local hum_ = char:FindFirstChildOfClass("Humanoid")
    if hum_ then hum_:UnequipTools() end
    task.wait(0.2)

    local shopFolder = workspace:FindFirstChild("Ignored") and workspace.Ignored:FindFirstChild("Shop")
    if not shopFolder then return end

    local skullMask = nil
    for _, item in pairs(shopFolder:GetChildren()) do
        if item.Name:lower():find("skull") or item.Name:lower():find("mask") then
            skullMask = item
            break
        end
    end

    if not skullMask then return end

    local headPart = skullMask:FindFirstChild("Head") or skullMask:FindFirstChildOfClass("BasePart")
    if not headPart then return end

    local cd = skullMask:FindFirstChild("ClickDetector")
    if not cd then
        for _, v in pairs(skullMask:GetDescendants()) do
            if v:IsA("ClickDetector") then cd = v; break end
        end
    end
    if not cd then return end

    local origCF = root_.CFrame
    local attempts = 0

    while not (player.Backpack:FindFirstChild("[Mask]") or player.Backpack:FindFirstChild("Mask") or char:FindFirstChild("Mask") or char:FindFirstChild("In-gameMask")) and attempts < 25 do
        char = player.Character
        root_ = char and char:FindFirstChild("HumanoidRootPart")
        if not root_ then break end
        root_.CFrame = CFrame.new(headPart.CFrame.Position + Vector3.new(0, -8, 0))
        task.wait(0.1)
        fireclickdetector(cd)
        task.wait(0.4)
        attempts += 1
    end

    char = player.Character
    root_ = char and char:FindFirstChild("HumanoidRootPart")
    if root_ and origCF then root_.CFrame = origCF end

    task.wait(0.3)
    local mask = player.Backpack:FindFirstChild("[Mask]") or player.Backpack:FindFirstChild("Mask")
    if mask then
        mask.Parent = char
        task.wait(0.3)
        pcall(function() mask:Activate() end)
        task.wait(0.5)
        char = player.Character
        local hum2 = char and char:FindFirstChildOfClass("Humanoid")
        if hum2 then hum2:UnequipTools() end
    end
end

function autoEquipMask()
    local player = game.Players.LocalPlayer
    local character = player.Character or player.CharacterAdded:Wait()
    local mask = player.Backpack:FindFirstChild("[Mask]") or player.Backpack:FindFirstChild("Mask")
    if mask then 
        character.Humanoid:EquipTool(mask)
    end
end

