    for _, P in pairs(PlayersClone:GetPlayers()) do
        if P ~= Client then
            local character = P.Character
            if character then
                local HRP = character:FindFirstChild("HumanoidRootPart")
                if HRP then HRP.Size = Vector3.new(hitboxsize,hitboxsize,hitboxsize); HRP.CanCollide = false end
            end
        end
    end
end)

