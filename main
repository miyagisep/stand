            elseif msgLower:match("^%!tp%s+([^%s]+)$") then
                handleGotoCommand(player.Name, msgLower:match("^%!tp%s+([^%s]+)$"))
            elseif msgLower:match("^%!sky%s+([^%s]+)$") then
